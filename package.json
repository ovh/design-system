{
  "name": "ods",
  "version": "0.0.0",
  "private": true,
  "description": "OVHCloud Design System",
  "author": "OVH SAS",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ovh/design-system.git"
  },
  "scripts": {
    "build:ci": "lerna run --stream build:ci",
    "build:prod": "lerna run --stream build:prod",
    "build:storybook": "pnpm build:storybook:deps && lerna run --stream build:storybook",
    "build:storybook:deps": "([ -d packages/ods-react/dist ] || pnpm --filter @ovhcloud/ods-react run build:prod) && ([ -d packages/ods-recipes/dist ] || pnpm --filter @ovhcloud/ods-recipes run build:prod) && ([ -d packages/themes/dist ] || pnpm --filter @ovhcloud/ods-themes run build:prod) && ([ -d packages/ods-react/src/components/accordion/documentation ] || pnpm doc)",
    "clean": "lerna run clean",
    "doc": "lerna run --concurrency 2 doc",
    "lint": "pnpm lint:ts && pnpm lint:scss",
    "lint:css": "lerna run --concurrency 2 lint:css",
    "lint:scss": "lerna run --concurrency 2 lint:scss",
    "lint:ts": "lerna run --concurrency 2 lint:ts",
    "new:component": "plop --plopfile scripts/component-generator/plopfile.js component",
    "new:recipe": "plop --plopfile scripts/recipe-generator/plopfile.js recipe",
    "ods:graduate": "pnpm ods:release:prepare && pnpm version:graduate",
    "ods:major": "pnpm ods:release:prepare && pnpm version:major",
    "ods:minor": "pnpm ods:release:prepare && pnpm version:minor",
    "ods:patch": "pnpm ods:release:prepare && pnpm version:patch",
    "ods:prepatch": "pnpm ods:release:prepare && pnpm version:prepatch",
    "ods:preminor": "pnpm ods:release:prepare && pnpm version:preminor",
    "ods:premajor": "pnpm ods:release:prepare && pnpm version:premajor",
    "ods:prerelease": "pnpm ods:release:prepare && pnpm version:prerelease",
    "ods:release:prepare": "npx zx scripts/ods-release-prepare.mjs",
    "ods:publish": "lerna publish --concurrency 1 from-package --yes",
    "storybook": "pnpm build:storybook:deps && pnpm --filter @ovhcloud/ods-storybook run start",
    "test:e2e:ci": "lerna run --stream --concurrency 1 test:e2e:ci",
    "test:spec:ci": "lerna run --stream --concurrency 2 test:spec:ci",
    "test:wrapper:react": "lerna run --stream --concurrency 1 test:wrapper:react",
    "test:wrapper:vue": "lerna run --stream --concurrency 1 test:wrapper:vue",
    "version": "pnpm install && git add pnpm-lock.yaml && echo \"more info, see: https://github.com/lerna/lerna/issues/2891#issuecomment-953823502\"",
    "version:graduate": "lerna version --conventional-commits --exact --force-publish --conventional-graduate",
    "version:major": "lerna version major --conventional-commits --exact --force-publish",
    "version:minor": "lerna version minor --conventional-commits --exact --force-publish",
    "version:patch": "lerna version patch --conventional-commits --exact --force-publish",
    "version:prepatch": "lerna version prepatch --conventional-commits --exact --force-publish --conventional-prerelease",
    "version:preminor": "lerna version preminor --conventional-commits --exact --force-publish --conventional-prerelease",
    "version:premajor": "lerna version premajor --conventional-commits --exact --force-publish --conventional-prerelease",
    "version:prerelease": "lerna version --conventional-commits --exact --force-publish --conventional-prerelease",
    "prepare": "husky"
  },
  "devDependencies": {
    "@ovhcloud/ods-themes": "workspace:*",
    "jest": "30.4.2",
    "sass": "1.101.0",
    "start-server-and-test": "3.0.11",
    "storybook": "8.6.12",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.2",
    "@eslint/compat": "2.1.0",
    "@eslint/js": "10.0.1",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "conventional-changelog-angular": "7.0.0",
    "eslint": "10.5.0",
    "eslint-html-reporter": "0.7.4",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-tsdoc": "0.5.2",
    "husky": "9.1.7",
    "lerna": "9.0.7",
    "plop": "4.0.5",
    "rimraf": "6.1.3",
    "stylelint": "17.14.0",
    "stylelint-config-concentric-order": "5.5.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-formatter-html": "1.0.1"
  },
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">= 22",
    "pnpm": ">= 9"
  }
}
