{
  "name": "@ovhcloud/ods-react-tooltip",
  "version": "19.7.3",
  "private": true,
  "description": "ODS React Tooltip component",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rimraf documentation",
    "doc": "pnpm run clean && pnpm run doc:ts && pnpm run doc:css",
    "doc:css": "sass src/components:documentation --no-source-map --pkg-importer=node && node ../../../scripts/generate-component-token-list.js",
    "doc:ts": "typedoc",
    "lint:scss": "stylelint --aei 'src/components/**/*.scss'",
    "lint:ts": "eslint '{src,tests}/**/*.{js,ts,tsx}'",
    "start": "pnpm run start:storybook",
    "start:storybook": "storybook dev -p 3000 --no-open",
    "test:e2e": "E2E=true start-server-and-test 'pnpm run start:storybook' 3000 'jest -i --detectOpenHandles'",
    "test:e2e:ci": "CI=true pnpm run test:e2e",
    "test:spec": "jest --passWithNoTests",
    "test:spec:ci": "pnpm run test:spec"
  }
}
