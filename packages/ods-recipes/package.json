{
  "name": "@ovhcloud/ods-recipes",
  "version": "19.7.3",
  "description": "ODS Recipes",
  "author": "OVH SAS",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ovh/design-system.git",
    "directory": "packages/ods-recipes"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./json": {
      "default": "./dist/ods-recipes.json"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build:prod": "rimraf dist && tsc -b && vite build && npm run generate:json",
    "build:scripts": "rimraf scripts/dist && tsc -b && vite build --outDir scripts/dist -c scripts/vite.config.js",
    "clean": "rimraf dist && rimraf scripts/dist",
    "generate:json": "npm run build:scripts && node scripts/generate-recipes-json.js",
    "lint:ts": "eslint 'src/constants/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "@ovhcloud/ods-react": "workspace:*",
    "@ovhcloud/ods-themes": "workspace:*",
    "classnames": "2.5.1"
  },
  "devDependencies": {
    "@storybook/react": "8.6.12",
    "@storybook/react-vite": "8.6.12",
    "@types/react": "18.2.56",
    "@types/react-dom": "18.2.25",
    "@vitejs/plugin-react": "5.2.0",
    "autoprefixer": "10.4.17",
    "glob": "13.0.6",
    "postcss": "8.4.35",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "sass": "1.101.0",
    "storybook": "8.6.12",
    "string-hash": "1.1.3",
    "tailwindcss": "3.4.18",
    "typescript": "6.0.3",
    "vite": "6.2.0",
    "vite-plugin-dts": "5.0.3",
    "vite-plugin-lib-inject-css": "2.2.2"
  }
}
