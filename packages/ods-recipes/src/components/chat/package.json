{
  "name": "@ovhcloud/ods-recipes-chat",
  "version": "19.7.2",
  "private": true,
  "description": "ODS Recipes Chat",
  "type": "module",
  "main": "dist/index.js",
  "dependencies": {
    "@ovhcloud/ods-react": "workspace:*"
  },
  "scripts": {
    "clean": "rimraf node_modules",
    "lint:css": "stylelint --aei 'src/**/*.css'",
    "lint:scss": "stylelint --aei 'src/**/*.scss'",
    "lint:ts": "eslint 'src/**/*.{js,ts,tsx}' --ignore-pattern '*.stories.tsx'",
    "start": "pnpm run start:storybook",
    "start:storybook": "storybook dev -p 3000 --no-open"
  }
}
