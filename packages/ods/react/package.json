{
  "name": "@ovhcloud/ods-components-react",
  "version": "18.4.1",
  "private": true,
  "description": "React specific wrapper for ods",
  "keywords": [],
  "author": "OVH SAS",
  "license": "Apache-2.0",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "build0": "npm run clean && npm run compile",
    "clean": "rimraf dist",
    "compile": "npm run compile:esm && npm run compile:cjs",
    "compile:esm": "tsc -p tsconfig.json",
    "compile:cjs": "tsc -p tsconfig.cjs.json",
    "test:react:e2e": "concurrently -s first -k \"npm run start --prefix tests/_app\" \"wait-on http://localhost:3000 && jest -i -c tests/jest.config.js\"",
    "test:react:e2e:ci": "concurrently -s first -k \"npm run start --prefix tests/_app\" \"node ../scripts/wait-for-http.js http://localhost:3000 && jest -i -c tests/jest.config.js\"",
    "test:react:testing-library": "jest -c ./testing-library/jest.config.ts",
    "test:wrapper:react": "npm run test:react:e2e:ci && npm run test:react:testing-library"
  },
  "main0": "dist/cjs/index.js",
  "module0": "dist/esm/index.js",
  "types0": "dist/types/index.d.ts",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./ods-accordion": {
      "import": "./dist/components/stencil-generated/OdsAccordion.js",
      "types": "./dist/types/components/stencil-generated/OdsAccordion.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "peerDependencies": {
    "react": ">=16.8.6",
    "react-dom": ">=16.8.6"
  },
  "dependencies": {
    "@ovhcloud/ods-components": "*",
    "@stencil/react-output-target": "0.8.1"
  },
  "devDependencies": {
    "@babel/core": "7.26.0",
    "@babel/plugin-transform-modules-commonjs": "7.25.9",
    "@babel/preset-env": "7.26.0",
    "@babel/preset-typescript": "7.26.0",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.0.1",
    "@testing-library/user-event": "14.5.2",
    "babel-jest": "29.7.0"
  }
}
